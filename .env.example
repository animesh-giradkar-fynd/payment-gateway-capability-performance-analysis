# Copy this file to .env.local and fill in values. .env.local is gitignored.

# NextAuth — required
# NEXTAUTH_SECRET: generate via `openssl rand -base64 32`
# NEXTAUTH_URL: must match the URL the app is reachable at
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=

# Google OAuth client — required for sign-in
# Provision via GCP Console → APIs & Services → Credentials → Create OAuth 2.0 Client ID
# Application type: Web application
# Authorized redirect URI (local): http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Domain restriction enforced in NextAuth's signIn callback (D005)
ALLOWED_EMAIL_DOMAIN=gofynd.com

# BigQuery — Zenith dataset (D006)
BQ_PROJECT=fynd-jio-commerceml-prod
BQ_DATASET=fynd_zenith_data
# BQ region. Confirm with data team; common alternatives are 'US', 'asia-south1'.
BQ_LOCATION=US

# Service account JSON (single-line, escaped) — REQUIRED FOR VERCEL ONLY (D008).
# Leave blank for local dev — the BQ client falls back to Application Default Credentials
# via `gcloud auth application-default login`.
GCP_SERVICE_ACCOUNT_JSON=
